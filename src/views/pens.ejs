<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3>Pen Management Portfolio</h3>
  <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#addPenModal"><i class="fa-solid fa-plus me-1"></i>Add New Pen</button>
</div>

<% if (successMsg) { %><div class="alert alert-success p-2 small"><%= successMsg %></div><% } %>
<% if (errorMsg) { %><div class="alert alert-danger p-2 small"><%= errorMsg %></div><% } %>

<div class="row">
  <% pens.forEach(pen => { %>
    <div class="col-md-4 mb-4">
      <div class="card h-100 border-0 shadow-sm">
        <img src="<%= pen.image %>" class="card-img-top" style="height: 220px; object-fit: cover;" onerror="this.src='https://placehold.co/400x220?text=No+Preview'">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title h6 mb-1 text-dark text-truncate"><%= pen.penName %></h5>
          <div class="small text-muted mb-2">Brand: <span class="badge bg-secondary"><%= pen.brand ? pen.brand.brandName : 'Unassigned' %></span></div>
          <p class="card-text text-muted small text-truncate-3 flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;"><%= pen.penDescription %></p>
          
          <div class="d-flex align-items-center gap-2 my-2">
            <span class="badge bg-danger">Discount: <%= (pen.off * 100).toFixed(0) %>%</span>
            <span class="badge bg-light text-dark border">Pouch: <%= pen.pouch ? 'Included' : 'None' %></span>
            <span class="ms-auto">
              <% if (pen.gender) { %><i class="fa-solid fa-mars text-primary fs-5"></i><% } else { %><i class="fa-solid fa-venus text-danger fs-5"></i><% } %>
            </span>
          </div>

          <div class="d-flex justify-content-center mt-3 pt-2 border-top">
            <a href="/admin/pens/<%= pen._id %>" class="btn btn-outline-dark btn-sm w-100"><i class="fa-solid fa-eye me-1"></i>View Details</a>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<div class="modal fade" id="addPenModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/admin/pens" method="POST">
        <div class="modal-header"><h5 class="modal-title">Create Pen Document</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="mb-2"><label class="form-label small">Pen Name</label><input type="text" name="penName" class="form-control" pattern="[A-Za-z\s]+" title="Letters and spaces only" required></div>
          <div class="mb-2"><label class="form-label small">Description</label><textarea name="penDescription" class="form-control" rows="2" required></textarea></div>
          <div class="mb-2"><label class="form-label small">Image URL</label><input type="url" name="image" class="form-control" required></div>
          <div class="mb-2"><label class="form-label small">Off Value (0 - 1)</label><input type="number" name="off" class="form-control" min="0" max="1" step="0.01" required></div>
          <div class="mb-3"><label class="form-label small">Brand</label>
            <select name="brand" class="form-select" required>
              <option value="">Select brand...</option>
              <% brands.forEach(b => { %><option value="<%= b._id %>"><%= b.brandName %></option><% }) %>
            </select>
          </div>
          <div class="form-check form-switch mb-1"><input class="form-check-input" type="checkbox" name="pouch"><label class="form-check-label small">Has Premium Pouch</label></div>
          <div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="gender"><label class="form-check-label small">Gender (On = Male / Off = Female)</label></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button><button type="submit" class="btn btn-dark btn-sm">Save</button></div>
      </form>
    </div>
  </div>
</div>

<%- include('partials/footer') %>