<%- include('partials/header') %>

<div class="mb-4">
  <a href="/admin/pens" class="btn btn-outline-dark btn-sm"><i class="fa-solid fa-arrow-left me-1"></i>Back to Pen Portfolio</a>
</div>

<% if (successMsg) { %><div class="alert alert-success p-2 small"><%= successMsg %></div><% } %>
<% if (errorMsg) { %><div class="alert alert-danger p-2 small"><%= errorMsg %></div><% } %>

<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card border-0 shadow-sm">
      <div class="row g-0">
        <div class="col-md-5">
          <img src="<%= pen.image %>" class="img-fluid rounded-start h-100 w-100" style="object-fit: cover; min-height: 300px;" onerror="this.src='https://placehold.co/400x300?text=No+Preview'">
        </div>
        <div class="col-md-7">
          <div class="card-body d-flex flex-column h-100 p-4">
            <h4 class="card-title text-dark mb-1"><%= pen.penName %></h4>
            <div class="mb-3">
              Brand: <span class="badge bg-secondary"><%= pen.brand ? pen.brand.brandName : 'Unassigned' %></span>
            </div>
            
            <p class="card-text text-muted mb-4"><%= pen.penDescription %></p>
            
            <div class="row mb-4">
              <div class="col-6">
                <span class="text-muted d-block small">Discount Value:</span>
                <span class="badge bg-danger fs-6"><%= (pen.off * 100).toFixed(0) %>% Off</span>
              </div>
              <div class="col-6">
                <span class="text-muted d-block small">Premium Pouch:</span>
                <span class="badge bg-light text-dark border fs-6"><%= pen.pouch ? 'Included' : 'None' %></span>
              </div>
            </div>

            <div class="mb-4">
              <span class="text-muted d-block small">Suitable Gender:</span>
              <span>
                <% if (pen.gender) { %>
                  <i class="fa-solid fa-mars text-primary fs-4 me-1"></i> Male
                <% } else { %>
                  <i class="fa-solid fa-venus text-danger fs-4 me-1"></i> Female
                <% } %>
              </span>
            </div>
            
            <div class="d-flex justify-content-between mt-auto pt-3 border-top">
              <button class="btn btn-warning btn-sm px-3" onclick="triggerEditModal('<%= JSON.stringify(pen) %>')"><i class="fa-solid fa-edit me-1"></i>Edit Pen</button>
              <form action="/admin/pens/<%= pen._id %>?_method=DELETE" method="POST" onsubmit="return confirm('Are you sure you want to delete this pen?');">
                <button type="submit" class="btn btn-danger btn-sm px-3"><i class="fa-solid fa-trash me-1"></i>Delete Pen</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="editPenModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <form id="editPenForm" method="POST">
        <div class="modal-header bg-dark text-white"><h5 class="modal-title">Edit Pen Document</h5><button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button></div>
        <div class="modal-body">
          <div class="mb-2"><label class="form-label small">Pen Name</label><input type="text" name="penName" id="e_name" class="form-control" pattern="[A-Za-z\s]+" required></div>
          <div class="mb-2"><label class="form-label small">Description</label><textarea name="penDescription" id="e_desc" class="form-control" rows="2" required></textarea></div>
          <div class="mb-2"><label class="form-label small">Image URL</label><input type="url" name="image" id="e_image" class="form-control" required></div>
          <div class="mb-2"><label class="form-label small">Off Value (0 - 1)</label><input type="number" name="off" id="e_off" class="form-control" min="0" max="1" step="0.01" required></div>
          <div class="mb-3"><label class="form-label small">Brand</label>
            <select name="brand" id="e_brand" class="form-select" required>
              <% brands.forEach(b => { %><option value="<%= b._id %>"><%= b.brandName %></option><% }) %>
            </select>
          </div>
          <div class="form-check form-switch mb-1"><input class="form-check-input" type="checkbox" name="pouch" id="e_pouch"><label class="form-check-label small">Has Premium Pouch</label></div>
          <div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="gender" id="e_gender"><label class="form-check-label small">Gender (On = Male / Off = Female)</label></div>
        </div>
        <div class="modal-footer"><button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button><button type="submit" class="btn btn-warning btn-sm">Update</button></div>
      </form>
    </div>
  </div>
</div>

<script>
  function triggerEditModal(raw) {
    const data = JSON.parse(raw);
    document.getElementById('editPenForm').action = '/admin/pens/' + data._id + '?_method=PUT';
    document.getElementById('e_name').value = data.penName;
    document.getElementById('e_desc').value = data.penDescription;
    document.getElementById('e_image').value = data.image;
    document.getElementById('e_off').value = data.off;
    document.getElementById('e_brand').value = data.brand._id || data.brand;
    document.getElementById('e_pouch').checked = data.pouch;
    document.getElementById('e_gender').checked = data.gender;
    new bootstrap.Modal(document.getElementById('editPenModal')).show();
  }
</script>

<%- include('partials/footer') %>
