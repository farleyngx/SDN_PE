<%- include('partials/header') %>
<div class="row justify-content-center mt-5">
  <div class="col-md-4">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h4 class="card-title text-center mb-4">Member Access Portal</h4>
        <% if (error) { %>
          <div class="alert alert-danger p-2 small"><%= error %></div>
        <% } %>
        <form action="/auth/access" method="POST">
          <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" name="name" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">Code</label>
            <input type="password" name="code" class="form-control" required>
          </div>
          <button type="submit" class="btn btn-dark w-100 mt-2">Login</button>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>